# Activate the flake development shell when direnv is available.
# Requires nix-direnv or a direnv that supports `use flake`.
use flake

# --- nxr shell completions (session-local) -----------------------------------
# `nxr completion` is already implemented for bash/zsh/fish. direnv cannot
# install shell functions into the parent shell, so we:
#   1. materialize scripts under .direnv/ (also installed on the nix package)
#   2. extend FPATH / XDG_DATA_DIRS for shells that scan those paths
#   3. export NXR_COMPLETION_HOOK for interactive zsh (see shell/direnv-zsh-hook.zsh)
#
# Zsh users: add once after `eval "$(direnv hook zsh)"` in ~/.zshrc:
#   [[ -f "${NXR_COMPLETION_HOOK:-}" ]] && source "$NXR_COMPLETION_HOOK"
# or rely on the precmd helper documented in docs/DEV_ENV_INTEGRATION.md.

if has nxr; then
  _nxr_layout="$(direnv_layout_dir)/nxr-completions"
  mkdir -p \
    "${_nxr_layout}/zsh/site-functions" \
    "${_nxr_layout}/bash-completion/completions" \
    "${_nxr_layout}/fish/vendor_completions.d"

  _nxr_ver="$(nxr --version 2>/dev/null || true)"
  _nxr_stamp="${_nxr_layout}/.stamp"
  if [[ ! -f "${_nxr_stamp}" || "$(cat "${_nxr_stamp}" 2>/dev/null)" != "${_nxr_ver}" ]]; then
    nxr completion zsh >"${_nxr_layout}/zsh/site-functions/_nxr"
    nxr completion bash >"${_nxr_layout}/bash-completion/completions/nxr"
    nxr completion fish >"${_nxr_layout}/fish/vendor_completions.d/nxr.fish"
    printf '%s\n' "${_nxr_ver}" >"${_nxr_stamp}"
  fi

  path_add XDG_DATA_DIRS "${_nxr_layout}"
  path_add FPATH "${_nxr_layout}/zsh/site-functions"

  export NXR_COMPLETION_DIR="${_nxr_layout}"
  export NXR_COMPLETION_HOOK="${PWD}/shell/direnv-zsh-hook.zsh"

  unset _nxr_layout _nxr_ver _nxr_stamp
fi
